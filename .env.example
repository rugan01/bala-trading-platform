# Copy this file to .env and fill in real values locally.

# ---------------------------------------------------------------------------
# Primary Upstox keys
# ---------------------------------------------------------------------------
UPSTOX_ACCESS_TOKEN=
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=http://localhost:3000/callback
UPSTOX_TOKEN_REFRESHED_AT=

# ---------------------------------------------------------------------------
# Account-specific Upstox credentials
# ---------------------------------------------------------------------------
UPSTOX_BALA_API_KEY=
UPSTOX_BALA_API_SECRET=
UPSTOX_BALA_REDIRECT_URI=http://localhost:3000/callback
UPSTOX_BALA_MOBILE=
UPSTOX_BALA_PIN=
UPSTOX_BALA_TOTP_SECRET=
UPSTOX_BALA_PASSWORD=
UPSTOX_BALA_ACCESS_TOKEN=
UPSTOX_BALA_TOKEN_REFRESHED_AT=

UPSTOX_NIMMY_API_KEY=
UPSTOX_NIMMY_API_SECRET=
UPSTOX_NIMMY_REDIRECT_URI=http://localhost:3000/callback
UPSTOX_NIMMY_MOBILE=
UPSTOX_NIMMY_PIN=
UPSTOX_NIMMY_TOTP_SECRET=
UPSTOX_NIMMY_PASSWORD=
UPSTOX_NIMMY_ACCESS_TOKEN=
UPSTOX_NIMMY_TOKEN_REFRESHED_AT=

# ---------------------------------------------------------------------------
# Notion
# ---------------------------------------------------------------------------
NOTION_API_KEY=
NOTION_TRADING_JOURNAL_DB=
NOTION_WF_DB_ID=

# ---------------------------------------------------------------------------
# Telegram
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------------------------------------------------------------------------
# Optional broker XLSX/UCC mapping for journal backfill auto-detection
# ---------------------------------------------------------------------------
BROKER_UCC_BALA=
BROKER_UCC_NIMMY=

# ---------------------------------------------------------------------------
# Optional walk-forward overrides
# ---------------------------------------------------------------------------
WFV_PROFILE_ID=silvermic_v3_default
WFV_STRATEGY_ID=silvermic_cpr_band_v3
